{
  "manifest_version": 3,
  "name": "CrosswordChat",
  "version": "0.13.10",
  "description": "Solve the New York Times crossword conversationally: it reads clues aloud, you answer by voice.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "tts",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://www.nytimes.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "CrosswordChat — start/stop voice session",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.nytimes.com/crosswords*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.nytimes.com/crosswords*"
      ],
      "js": [
        "main-world.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
