{
  "manifest_version": 3,
  "name": "CrosswordChat",
  "version": "0.9.0",
  "description": "Solve the New York Times crossword conversationally: it reads clues aloud, you answer by voice.",
  "minimum_chrome_version": "116",
  "permissions": [
    "tts",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.nytimes.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "CrosswordChat — start/stop voice session"
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.nytimes.com/crosswords*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.nytimes.com/crosswords*"
      ],
      "js": [
        "main-world.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
